.page {
  min-height: 100vh;
  padding: 36rpx 32rpx 64rpx;
  overflow: hidden;
  background: #F7FAFC;
  color: #173042;
}

.top-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.eyebrow,
.page-title { display: block; }
.eyebrow {
  color: #5F7482;
  font-size: 19rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
}
.page-title {
  margin-top: 8rpx;
  font-size: 40rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.connection-pill {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 148rpx;
  min-height: 88rpx;
  margin: 0;
  padding: 0 22rpx;
  border: 1rpx solid #DCE6EA;
  border-radius: 999rpx;
  color: #5F7482;
  background: #FFFFFF;
  font-size: 24rpx;
  line-height: 1;
  box-shadow: 0 8rpx 28rpx rgba(23, 48, 66, 0.05);
}
.connection-pill.online { color: #327572; }
.connection-dot {
  width: 12rpx;
  height: 12rpx;
  margin-right: 10rpx;
  border-radius: 50%;
  background: #AAB8C0;
}
.connection-pill.online .connection-dot { background: #65AAA7; }

.guardian-hero {
  position: relative;
  width: 390rpx;
  height: 390rpx;
  margin: 54rpx auto 20rpx;
}
.guardian-orbit,
.guardian-core {
  position: absolute;
  left: 50%;
  top: 50%;
  border-radius: 50%;
  transform: translate(-50%, -50%);
}
.guardian-orbit {
  border: 2rpx solid rgba(170, 184, 192, 0.34);
  transition: border-color 240ms ease;
}
.orbit-back { width: 346rpx; height: 346rpx; opacity: 0.34; }
.orbit-front {
  width: 286rpx;
  height: 286rpx;
  animation: orbit-breathe 3.2s ease-in-out infinite;
}
.orbit-dot {
  position: absolute;
  right: 17rpx;
  bottom: 48rpx;
  width: 18rpx;
  height: 18rpx;
  border: 8rpx solid #F7FAFC;
  border-radius: 50%;
  background: #AAB8C0;
}
.guardian-core {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 208rpx;
  height: 208rpx;
  background: #F1F5F6;
  box-shadow: 0 24rpx 70rpx rgba(170, 184, 192, 0.18);
  transition: background-color 240ms ease, box-shadow 240ms ease;
}
.shield-shape {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 124rpx;
  height: 142rpx;
  border: 5rpx solid #AAB8C0;
  border-radius: 62rpx 62rpx 72rpx 72rpx;
  color: #AAB8C0;
  background: #FFFFFF;
  transition: border-color 240ms ease, color 240ms ease;
}
.mode-guarding .guardian-orbit,
.mode-recovered .guardian-orbit { border-color: rgba(101, 170, 167, 0.34); }
.mode-guarding .orbit-dot,
.mode-recovered .orbit-dot { background: #65AAA7; }
.mode-guarding .guardian-core,
.mode-recovered .guardian-core { background: #EAF5F4; box-shadow: 0 24rpx 70rpx rgba(101, 170, 167, 0.18); }
.mode-guarding .shield-shape,
.mode-recovered .shield-shape { border-color: #65AAA7; color: #65AAA7; }
.mode-warning .guardian-orbit { border-color: rgba(229, 132, 90, 0.34); }
.mode-warning .orbit-dot { background: #E5845A; }
.mode-warning .guardian-core { background: #FCF0EA; box-shadow: 0 24rpx 70rpx rgba(229, 132, 90, 0.18); }
.mode-warning .shield-shape { border-color: #E5845A; color: #E5845A; }
.mode-arrived .guardian-orbit { border-color: rgba(99, 180, 135, 0.34); }
.mode-arrived .orbit-dot { background: #63B487; }
.mode-arrived .guardian-core { background: #EAF6EF; box-shadow: 0 24rpx 70rpx rgba(99, 180, 135, 0.18); }
.mode-arrived .shield-shape { border-color: #63B487; color: #63B487; }
.state-glyph { font-size: 70rpx; font-weight: 600; line-height: 1; }
.state-glyph.heart { font-size: 62rpx; }
.state-glyph.check { font-size: 58rpx; }
.mode-warning .orbit-front { animation: warning-pulse 1.8s ease-out infinite; }

.status-copy { text-align: center; }
.status-title {
  display: block;
  font-size: 62rpx;
  font-weight: 700;
  letter-spacing: 3rpx;
}
.status-subtitle {
  display: block;
  margin-top: 16rpx;
  color: #5F7482;
  font-size: 28rpx;
}

.timeline-card,
.safe-card,
.alert-actions {
  margin-top: 42rpx;
  padding: 24rpx 28rpx;
  border: 1rpx solid #E4ECEF;
  border-radius: 24rpx;
  background: #FFFFFF;
  box-shadow: 0 14rpx 38rpx rgba(23, 48, 66, 0.055);
}
.timeline-row {
  display: flex;
  align-items: flex-start;
  min-height: 76rpx;
  padding: 14rpx 0;
}
.timeline-marker {
  flex: 0 0 auto;
  width: 16rpx;
  height: 16rpx;
  margin: 12rpx 18rpx 0 0;
  border: 6rpx solid #E8F0F2;
  border-radius: 50%;
  background: #65AAA7;
}
.timeline-marker.warning { background: #E5845A; border-color: #FCE9E0; }
.timeline-marker.success { background: #63B487; border-color: #E3F3E9; }
.timeline-time {
  flex: 0 0 88rpx;
  color: #526977;
  font-size: 25rpx;
  line-height: 40rpx;
  font-variant-numeric: tabular-nums;
}
.timeline-copy { flex: 1; min-width: 0; }
.timeline-title { display: block; font-size: 27rpx; font-weight: 600; line-height: 40rpx; }
.timeline-summary { display: block; margin-top: 4rpx; color: #5F7482; font-size: 23rpx; }

.alert-note { display: block; color: #5F7482; font-size: 25rpx; text-align: center; }
.ack-button,
.connect-button {
  min-height: 92rpx;
  margin-top: 22rpx;
  border-radius: 20rpx;
  color: #FFFFFF;
  background: #173042;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 92rpx;
}
.ack-button.done { color: #327572; background: #EAF5F4; }

.safe-card-head { display: flex; align-items: center; }
.safe-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  margin-right: 18rpx;
  border: 3rpx solid #63B487;
  border-radius: 18rpx;
  color: #3B7D5C;
  font-size: 34rpx;
  font-weight: 700;
}
.safe-title { font-size: 32rpx; font-weight: 700; }
.safe-summary { display: block; margin-top: 22rpx; color: #526977; font-size: 26rpx; line-height: 1.75; }

.trips-link {
  min-height: 88rpx;
  margin-top: 20rpx;
  color: #526977;
  background: transparent;
  font-size: 25rpx;
  line-height: 88rpx;
}

.sheet-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 20;
  background: rgba(23, 48, 66, 0.28);
}
.connection-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 21;
  padding: 20rpx 32rpx calc(44rpx + env(safe-area-inset-bottom));
  border-radius: 34rpx 34rpx 0 0;
  background: #FFFFFF;
}
.sheet-handle { width: 72rpx; height: 8rpx; margin: 0 auto 28rpx; border-radius: 8rpx; background: #D9E3E7; }
.sheet-title { display: block; font-size: 36rpx; font-weight: 700; }
.sheet-help { display: block; margin-top: 10rpx; color: #5F7482; font-size: 24rpx; }
.address-input {
  min-height: 92rpx;
  margin-top: 28rpx;
  padding: 0 24rpx;
  border: 2rpx solid #DCE6EA;
  border-radius: 18rpx;
  color: #173042;
  background: #F7FAFC;
  font-size: 28rpx;
}

@keyframes orbit-breathe {
  0%, 100% { opacity: 0.48; transform: translate(-50%, -50%) scale(0.96); }
  50% { opacity: 1; transform: translate(-50%, -50%) scale(1.04); }
}
@keyframes warning-pulse {
  0% { opacity: 0.8; transform: translate(-50%, -50%) scale(0.94); }
  70%, 100% { opacity: 0.18; transform: translate(-50%, -50%) scale(1.12); }
}
@media (prefers-reduced-motion: reduce) {
  .orbit-front,
  .mode-warning .orbit-front { animation: none; }
}
